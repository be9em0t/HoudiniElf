{
  "name": "pi-vscode-extension",
  "displayName": "Pi",
  "description": "Pi agent sidebar powered by pi SDK",
  "version": "0.0.1",
  "publisher": "local",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/be9em0t/HoudiniElf.git",
    "directory": "tools_Vla/pi-vscode/pi-vscode-extension"
  },
  "type": "module",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:piSidebar",
    "onCommand:pi.openSidebar",
    "onCommand:pi.openLogs",
    "onCommand:pi.selectModel",
    "onCommand:pi.addExternalRoot"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pi.openSidebar",
        "title": "Pi: Open Sidebar"
      },
      {
        "command": "pi.selectWorkspaceRoot",
        "title": "Pi: Select Workspace Root"
      },
      {
        "command": "pi.selectModel",
        "title": "Pi: Select Model"
      },
      {
        "command": "pi.openLogs",
        "title": "Pi: Open Logs"
      },
      {
        "command": "pi.addExternalRoot",
        "title": "Pi: Add External Access Root"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pi",
          "title": "Pi",
          "icon": "media/pi_logo.svg"
        }
      ]
    },
    "views": {
      "pi": [
        {
          "type": "webview",
          "id": "piSidebar",
          "name": "Pi"
        }
      ]
    },
    "configuration": {
      "title": "Pi",
      "properties": {
        "pi.workspaceRoot": {
          "type": "string",
          "default": "",
          "description": "Fallback workspace root when no folder is open"
        },
        "pi.favoriteModels": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Favorite models to surface at the top of the model picker. Use strings like \"github-copilot/oswe-vscode-prime\" or \"ollama/gemma4:latest\"."
        },
        "pi.externalRoots": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Additional external absolute paths Pi is allowed to access. Paths outside the workspace will ask for approval before use."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "playwright:mcp:start": "bash ./scripts/playwright-mcp.sh start",
    "playwright:mcp:stop": "bash ./scripts/playwright-mcp.sh stop",
    "playwright:mcp:status": "bash ./scripts/playwright-mcp.sh status",
    "playwright:mcp:logs": "bash ./scripts/playwright-mcp.sh logs"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.66.1",
    "@mariozechner/pi-coding-agent": "^0.66.1",
    "@sinclair/typebox": "^0.34.8",
    "@vscode/codicons": "^0.0.45"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.4",
    "vsce": "^2.15.0"
  }
}
